{
  "name": "toy-import-app",
  "version": "1.0.0",
  "description": "SAP CAP-based toy import and distribution platform",
  "main": "server.js",
  "scripts": {
    "start": "cds run",
    "dev": "cds watch",
    "build": "cds build --production",
    "test": "jest",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration",
    "test:e2e": "jest test/e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "deploy": "cf deploy mta_archives/toy-import-app.mtar"
  },
  "dependencies": {
    "@sap/cds": "^7.9.0",
    "@sap/hana-client": "^2.19.0",
    "@sap/xsenv": "^4.2.0",
    "@sap/xssec": "^3.6.0",
    "@ui5/webcomponents-react": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "axios": "^1.6.7",
    "lodash": "^4.17.21",
    "date-fns": "^3.3.1",
    "leaflet": "^1.9.4",
    "express": "^4.18.2",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^7.9.0",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/leaflet": "^1.9.8",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana"
      },
      "auth": {
        "kind": "xsuaa"
      }
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
