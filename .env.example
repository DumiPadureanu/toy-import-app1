# HANA Database Connection
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=your-db-user
HANA_PASSWORD=your-db-password
HANA_SCHEMA=your-schema-name

# Application Settings
NODE_ENV=development
PORT=4004

# External APIs
MAP_API_KEY=your-map-api-key
CARRIER_API_KEY=your-carrier-api-key
