{
  "server": {
    "port": 4004,
    "host": "localhost"
  },
  "db": {
    "kind": "hana",
    "pool": {
      "min": 2,
      "max": 10
    }
  },
  "features": {
    "fileUploads": true,
    "notifications": true,
    "realTimeTracking": true
  },
  "external": {
    "mapApi": {
      "provider": "leaflet",
      "tileServer": "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
    }
  }
}
